<Window x:Class="CardEditorGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="卡牌定义编辑器"
        Height="720" Width="960"
        MinHeight="560" MinWidth="760">
    <Window.Resources>
        <Style x:Key="DescriptionSwatch" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="BorderBrush" Value="#888" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="文件(_F)">
                <MenuItem Header="新建(_N)" Click="MenuNew_Click" InputGestureText="Ctrl+N" />
                <MenuItem Header="打开(_O)..." Click="MenuOpen_Click" InputGestureText="Ctrl+O" />
                <Separator />
                <MenuItem Header="保存(_S)" Click="MenuSave_Click" InputGestureText="Ctrl+S" />
                <MenuItem Header="另存为(_A)..." Click="MenuSaveAs_Click" />
                <MenuItem Header="保存并生成(_G)..." Click="MenuSaveAndGenerate_Click" />
                <Separator />
                <MenuItem Header="退出(_X)" Click="MenuExit_Click" />
            </MenuItem>
            <MenuItem Header="工具(_T)">
                <MenuItem Header="设置(_E)..." Click="MenuSettings_Click" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪" />
            </StatusBarItem>
        </StatusBar>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
            <StackPanel>
                <GroupBox Header="基本信息" Margin="0,0,0,10">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">类名</TextBlock>
                        <TextBox x:Name="TxtClassName" Grid.Row="0" Grid.Column="1" Margin="4" />
                        <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="8,4,0,4">卡牌名称</TextBlock>
                        <TextBox x:Name="TxtTitle" Grid.Row="0" Grid.Column="3" Margin="4" />

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">费用</TextBlock>
                        <TextBox x:Name="TxtEnergyCost" Grid.Row="1" Grid.Column="1" Margin="4" />

                        <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="8,4,0,4">卡池类型</TextBlock>
                        <ComboBox x:Name="CmbPoolType" Grid.Row="1" Grid.Column="3" Margin="4" IsEditable="False" />

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">卡牌类型</TextBlock>
                        <ComboBox x:Name="CmbCardType" Grid.Row="2" Grid.Column="1" Margin="4" IsEditable="False" />

                        <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="8,4,0,4">稀有度</TextBlock>
                        <ComboBox x:Name="CmbRarity" Grid.Row="2" Grid.Column="3" Margin="4" IsEditable="False" />

                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">目标类型</TextBlock>
                        <ComboBox x:Name="CmbTargetType" Grid.Row="3" Grid.Column="1" Margin="4" IsEditable="False" />

                        <CheckBox x:Name="ChkShowInLibrary" Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2"
                                  Margin="8,8,4,4" Content="在卡牌图鉴中显示" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="动态变量" Margin="0,0,0,10">
                    <DockPanel Margin="8">
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="添加一行" Width="88" Margin="0,0,8,0" Click="BtnAddVar_Click" />
                            <Button Content="删除选中" Width="88" Margin="0,0,8,0" Click="BtnRemoveVar_Click" />
                            <Button Content="模版管理" Width="88" Click="BtnManageTemplates_Click" />
                        </StackPanel>
                        <DataGrid x:Name="GridDynamicVars"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  MinHeight="160"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="kind" Binding="{Binding Kind}" Width="*" />
                                <DataGridTextColumn Header="baseValue" Binding="{Binding BaseValue}" Width="90" />
                                <DataGridTextColumn Header="upgradeValue" Binding="{Binding UpgradeValue}" Width="90" />
                                <DataGridTextColumn Header="finalValue" Binding="{Binding FinalValue}" Width="90" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </GroupBox>

                <GroupBox Header="打出效果 (CardPlayAction)" Margin="0,0,0,10">
                    <DockPanel Margin="8">
                        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,8"
                                   Text="按顺序执行。数值来源选「固定数值」可编辑 value；选某一 kind 则与上方动态变量表中同名字段绑定（取第一条）。可用上移/下移调整顺序。" />
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="添加操作" Width="88" Margin="0,0,8,0" Click="BtnAddPlayAction_Click" />
                            <Button Content="删除选中" Width="88" Margin="0,0,8,0" Click="BtnRemovePlayAction_Click" />
                            <Button Content="上移" Width="64" Margin="0,0,8,0" Click="BtnMovePlayActionUp_Click" />
                            <Button Content="下移" Width="64" Click="BtnMovePlayActionDown_Click" />
                        </StackPanel>
                        <DataGrid x:Name="GridCardPlayActions"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  MinHeight="120"
                                  HeadersVisibility="Column"
                                  BeginningEdit="GridCardPlayActions_BeginningEdit">
                            <DataGrid.Columns>
                                <DataGridComboBoxColumn x:Name="ColPlayActionType"
                                                        Header="操作类型"
                                                        SelectedItemBinding="{Binding ActionType, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="150" />
                                <DataGridComboBoxColumn x:Name="ColPlayActionValueBinding"
                                                        Header="数值来源"
                                                        SelectedValueBinding="{Binding ValueBinding, UpdateSourceTrigger=PropertyChanged}"
                                                        DisplayMemberPath="Display"
                                                        SelectedValuePath="Key"
                                                        Width="160" />
                                <DataGridTextColumn Header="value" Binding="{Binding Value}" Width="90" />
                                <DataGridTextColumn Header="notes" Binding="{Binding Notes}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </GroupBox>

                <GroupBox Header="卡牌描述（BBCode）" Margin="0,0,0,10">
                    <DockPanel Margin="8">
                        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,8"
                                   Text="左侧为源码；右侧为预览。颜色与动画类标签对同一段正文互斥（新选会替换原颜色/动画）。工具栏按钮在点下时已保存选区，避免失焦丢选区。" />
                        <ScrollViewer DockPanel.Dock="Top" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="粗体" MinWidth="40" Margin="0,0,6,0" PreviewMouseDown="DescriptionToolbar_PreviewMouseDown"
                                        Click="DescriptionWrapTag_Click" Tag="b|b|[b]|[/b]" />
                                <Button Content="斜体" MinWidth="40" Margin="0,0,6,0" PreviewMouseDown="DescriptionToolbar_PreviewMouseDown"
                                        Click="DescriptionWrapTag_Click" Tag="i|i|[i]|[/i]" />
                                <Button Content="下划线" MinWidth="52" Margin="0,0,6,0" PreviewMouseDown="DescriptionToolbar_PreviewMouseDown"
                                        Click="DescriptionWrapTag_Click" Tag="u|u|[u]|[/u]" />
                                <Button x:Name="BtnDescriptionColorMenu" Content="颜色 ▾" MinWidth="52" Margin="0,0,6,0"
                                        PreviewMouseDown="BtnDescriptionColorMenu_PreviewMouseDown">
                                    <Button.ContextMenu>
                                        <ContextMenu Closed="DescriptionColorMenu_Closed">
                                            <MenuItem Header="插入 [color=red]…" Click="DescriptionInsertColorRed_Click" />
                                            <Separator />
                                            <MenuItem Header="颜色简写（色块）" IsEnabled="False" />
                                            <MenuItem Click="DescriptionExclusiveWrapTag_Click" Tag="[aqua]|[/aqua]|aqua" StaysOpenOnClick="False">
                                                <MenuItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Style="{StaticResource DescriptionSwatch}" Background="#40E0D0" />
                                                        <TextBlock Text="aqua" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                    </StackPanel>
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <MenuItem Click="DescriptionExclusiveWrapTag_Click" Tag="[blue]|[/blue]|blue" StaysOpenOnClick="False">
                                                <MenuItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Style="{StaticResource DescriptionSwatch}" Background="#1E90FF" />
                                                        <TextBlock Text="blue" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                    </StackPanel>
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <MenuItem Click="DescriptionExclusiveWrapTag_Click" Tag="[gold]|[/gold]|gold" StaysOpenOnClick="False">
                                                <MenuItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Style="{StaticResource DescriptionSwatch}" Background="#FFD700" />
                                                        <TextBlock Text="gold" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                    </StackPanel>
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <MenuItem Click="DescriptionExclusiveWrapTag_Click" Tag="[green]|[/green]|green" StaysOpenOnClick="False">
                                                <MenuItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Style="{StaticResource DescriptionSwatch}" Background="#32CD32" />
                                                        <TextBlock Text="green" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                    </StackPanel>
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <MenuItem Click="DescriptionExclusiveWrapTag_Click" Tag="[orange]|[/orange]|orange" StaysOpenOnClick="False">
                                                <MenuItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Style="{StaticResource DescriptionSwatch}" Background="#FF8C00" />
                                                        <TextBlock Text="orange" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                    </StackPanel>
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <MenuItem Click="DescriptionExclusiveWrapTag_Click" Tag="[pink]|[/pink]|pink" StaysOpenOnClick="False">
                                                <MenuItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Style="{StaticResource DescriptionSwatch}" Background="#FF69B4" />
                                                        <TextBlock Text="pink" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                    </StackPanel>
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <MenuItem Click="DescriptionExclusiveWrapTag_Click" Tag="[purple]|[/purple]|purple" StaysOpenOnClick="False">
                                                <MenuItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Style="{StaticResource DescriptionSwatch}" Background="#9B30FF" />
                                                        <TextBlock Text="purple" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                    </StackPanel>
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <MenuItem Click="DescriptionExclusiveWrapTag_Click" Tag="[red]|[/red]|red" StaysOpenOnClick="False">
                                                <MenuItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Style="{StaticResource DescriptionSwatch}" Background="#FF4500" />
                                                        <TextBlock Text="red" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                    </StackPanel>
                                                </MenuItem.Header>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button x:Name="BtnDescriptionAnimationMenu" Content="动画 ▾" MinWidth="52" Margin="0,0,6,0"
                                        PreviewMouseDown="BtnDescriptionAnimationMenu_PreviewMouseDown">
                                    <Button.ContextMenu>
                                        <ContextMenu Closed="DescriptionAnimationMenu_Closed">
                                            <MenuItem Header="ancient_banner" Click="DescriptionExclusiveWrapTag_Click" Tag="[ancient_banner]|[/ancient_banner]|ancient_banner" />
                                            <MenuItem Header="fade_in" Click="DescriptionExclusiveWrapTag_Click" Tag="[fade_in]|[/fade_in]|fade_in" />
                                            <MenuItem Header="fly_in" Click="DescriptionExclusiveWrapTag_Click" Tag="[fly_in]|[/fly_in]|fly_in" />
                                            <MenuItem Header="jitter" Click="DescriptionExclusiveWrapTag_Click" Tag="[jitter]|[/jitter]|jitter" />
                                            <MenuItem Header="sine" Click="DescriptionExclusiveWrapTag_Click" Tag="[sine]|[/sine]|sine" />
                                            <MenuItem Header="thinky_dots" Click="DescriptionExclusiveWrapTag_Click" Tag="[thinky_dots]|[/thinky_dots]|thinky_dots" />
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="字体" MinWidth="40" Margin="0,0,6,0" PreviewMouseDown="DescriptionToolbar_PreviewMouseDown"
                                        Click="DescriptionWrapTag_Click" Tag="font|font|[font=Arial]|[/font]" />
                                <Button Content="字号" MinWidth="40" Margin="0,0,6,0" PreviewMouseDown="DescriptionToolbar_PreviewMouseDown"
                                        Click="DescriptionWrapTag_Click" Tag="size|size|[size=24]|[/size]" />
                            </StackPanel>
                        </ScrollViewer>
                        <Grid MinHeight="140">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="200" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="*" MinWidth="200" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtDescription" Grid.Column="0" AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#DDD" />
                            <RichTextBox x:Name="RtbDescriptionPreview" Grid.Column="2" IsReadOnly="True" IsDocumentEnabled="True"
                                         VerticalScrollBarVisibility="Auto" BorderThickness="1"
                                         FontFamily="Segoe UI" FontSize="12" />
                        </Grid>
                    </DockPanel>
                </GroupBox>

                <GroupBox Header="备注">
                    <TextBox x:Name="TxtNotes" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" MinHeight="80" Margin="8" />
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
