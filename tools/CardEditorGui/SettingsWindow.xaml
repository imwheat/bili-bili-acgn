<Window x:Class="CardEditorGui.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑器设置"
        Height="620" Width="560"
        MinHeight="520" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="默认命名空间" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox x:Name="TxtDefaultNamespace" Margin="0,0,0,12" />

            <TextBlock Text="卡牌 JSON 默认保存目录" FontWeight="SemiBold" Margin="0,0,0,4" />
            <DockPanel LastChildFill="True" Margin="0,0,0,12">
                <Button x:Name="BtnBrowseSaveDir" DockPanel.Dock="Right" Content="浏览…" Width="80" Margin="8,0,0,0" Click="BtnBrowseSaveDir_Click" />
                <TextBox x:Name="TxtDefaultSaveDirectory" />
            </DockPanel>

            <TextBlock Text="默认卡牌脚本（.cs）生成目录" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,4"
                       Text="代码生成器将卡牌类写入此文件夹；建议指向仓库内 BiliBiliACGNCode\Cards。" />
            <DockPanel LastChildFill="True" Margin="0,0,0,12">
                <Button x:Name="BtnBrowseScriptDir" DockPanel.Dock="Right" Content="浏览…" Width="80" Margin="8,0,0,0" Click="BtnBrowseScriptDir_Click" />
                <TextBox x:Name="TxtDefaultCardScriptOutputDirectory" />
            </DockPanel>

            <TextBlock Text="卡牌信息 JSON 路径（cards.json）" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,4"
                       Text="与游戏内本地化一致，通常为 BiliBiliACGN\localization\zhs\cards.json。保存时若名称/描述有变会写入；键为「命名空间第一段大写-类名大写 SNAKE_CASE」.title/.description。" />
            <DockPanel LastChildFill="True" Margin="0,0,0,12">
                <Button x:Name="BtnBrowseCardLocalizationJson" DockPanel.Dock="Right" Content="浏览…" Width="80" Margin="8,0,0,0" Click="BtnBrowseCardLocalizationJson_Click" />
                <TextBox x:Name="TxtCardLocalizationJsonPath" />
            </DockPanel>

            <TextBlock Text="卡池（保存在 exe 同目录 settings.json 内）" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,8"
                       Text="「类型名」写入卡牌 JSON 与生成代码（[Pool(typeof(...))]）；「显示名称」仅用于编辑器下拉，留空则下拉显示类型名。" />
        </StackPanel>

        <GroupBox Grid.Row="1" Header="卡池列表" Margin="0,0,0,12">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <DataGrid x:Name="GridPools" Grid.Row="0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          MinHeight="140"
                          Margin="0,0,0,8"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="类型名（输出）" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                        <DataGridTextColumn Header="显示名称（可选）" Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtNewPoolType" Grid.Column="0" Margin="0,0,8,0"
                             ToolTip="新卡池类型名，如 MyCardPool" />
                    <TextBox x:Name="TxtNewPoolDisplayName" Grid.Column="1" Margin="0,0,8,0"
                             ToolTip="可选，如下拉显示中文名" />
                    <Button Grid.Column="2" Content="添加" Width="64" Margin="0,0,8,0" Click="BtnAddPool_Click" />
                    <Button Grid.Column="3" Content="删除选中" Width="88" Click="BtnRemovePool_Click" />
                </Grid>
                <TextBlock Grid.Row="2" Foreground="Gray" FontSize="11" TextWrapping="Wrap"
                           Text="默认含 ColorlessCardPool（无色牌）、CurseCardPool（诅咒牌）、StatusCardPool（状态牌）；与 BUFF/关键字选项/模版等一并写入同目录 settings.json。" />
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0" MaxWidth="360">
                <TextBlock x:Name="TxtSettingsPath" Foreground="Gray" FontSize="11" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="TxtCardPoolPath" Foreground="Gray" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
            </StackPanel>
            <Button Content="确定" Width="88" Margin="0,0,8,0" IsDefault="True" Click="BtnOk_Click" />
            <Button Content="取消" Width="88" IsCancel="True" Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>
